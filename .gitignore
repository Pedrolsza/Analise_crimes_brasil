# ── Data files ────────────────────────────────────────────────────────────────
# SINESP raw Excel files: large (~28 MB each), download separately from dados.gov.br
data/raw/sinesp/

# Large binary/array formats — never committed
*.parquet
*.feather
*.pkl
*.pickle
*.h5
*.hdf5

# Excel/tabular binaries — committed CSVs are explicitly tracked
*.xlsx
*.xls
*.tsv

# ── Power BI ──────────────────────────────────────────────────────────────────
# Power BI binary files — not versioned (use data/powerbi/ CSVs instead)
*.pbix
*.pbit

